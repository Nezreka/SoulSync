slskd/slskd.exe
Storage/sync_status.json
.spotify_cache
slskd/config/slskd.example.yml
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# Encryption key (generated per-instance, lives next to database)
.encryption_key

# User-specific files (auto-created by the app if missing)
config/config.json
config/youtube_cookies.txt
# All app databases are live user data — never commit (music_library, video_library, …)
database/*.db
database/*.db-shm
database/*.db-wal
database/*.db.backup_*
database/*.histbak
database/api_call_history.json
# Runtime caches/download state are instance data, never source assets.
database/lib2_artwork/
downloads/

# Overlay/poster assets — generated per-instance, never commit: downloaded Kometa
# logo packs, cached clean bases + first-touch backups, rendered thumbnails, uploads
database/video_poster_assets/
storage/image_cache/
logs/*.log
logs/*.log.*

# Auto-downloaded binaries
bin/

# Development compose/config files
*.dev.yml

# Local-only testing directories and tooling
.tool-versions
Staging/
Transfer/
docker-compose.local-image.yml
*-container-inspect.json
# Any hidden folders
**/.*/
# …except GitHub Actions: CI gates (route-tree drift, tests) only run if
# the workflows are actually committed.
!.github/
